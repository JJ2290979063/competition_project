# Anthropic API
ANTHROPIC_API_KEY=your_api_key_here

# SSH 连接配置（远程模式）
SSH_HOST=192.168.1.100
SSH_PORT=22
SSH_USER=your_username
SSH_PASSWORD=your_password
# 或使用密钥
SSH_KEY_PATH=~/.ssh/id_rsa

# 运行模式：local（本地）或 remote（SSH）
AGENT_MODE=remote

# 安全配置
REQUIRE_CONFIRM_FOR_HIGH_RISK=true
MAX_RETRY_COUNT=3
